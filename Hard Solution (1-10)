Challenge 6: Maximum Product Subarray
nums = [2,3,-2,4]
max_prod = min_prod = res = nums[0]
for n in nums[1:]:
    if n < 0:
        max_prod, min_prod = min_prod, max_prod
    max_prod = max(n, max_prod*n)
    min_prod = min(n, min_prod*n)
    res = max(res, max_prod)
print(res)
