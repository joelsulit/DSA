Challenge 3: Longest Consecutive Streak
nums = [100, 4, 200, 1, 3, 2]
nums_set = set(nums)
longest = 0
for n in nums_set:
    if n-1 not in nums_set:
        current = n
        length = 1
        while current+1 in nums_set:
            current += 1
            length += 1
        longest = max(longest, length)
print(longest)
