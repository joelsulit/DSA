Challenge 14: Longest Subarray with Equal 0s and 1s
nums = [0,1,0]
count = {0:-1}
curr = 0
max_len = 0
for i,n in enumerate(nums):
    curr += 1 if n==1 else -1
    if curr in count:
        max_len = max(max_len, i - count[curr])
    else:
        count[curr] = i
print(max_len)
