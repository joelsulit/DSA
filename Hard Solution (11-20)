Challenge 13: Count Subarrays with Given Sum
nums = [1,1,1]
target = 2
count = 0
prefix = {0:1}
curr_sum = 0
for n in nums:
    curr_sum += n
    count += prefix.get(curr_sum-target,0)
    prefix[curr_sum] = prefix.get(curr_sum,0)+1
