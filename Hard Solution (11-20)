Challenge 19: Valid Parentheses
s = "{[()]}"
stack = []
pairs = {')':'(', '}':'{', ']':'['}
valid = True
for c in s:
    if c in '({[':
        stack.append(c)
    else:
        if not stack or stack[-1]!=pairs[c]:
            valid = False
            break
        stack.pop()
print(valid)
