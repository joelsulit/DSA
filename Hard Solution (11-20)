Challenge 11: Minimum Size Subarray Sum
nums = [2,3,1,2,4,3]
target = 7
min_len = float('inf')
start = 0
curr_sum = 0
for end in range(len(nums)):
    curr_sum += nums[end]
    while curr_sum >= target:
        min_len = min(min_len, end - start + 1)
        curr_sum -= nums[start]
        start += 1
print(min_len if min_len != float('inf') else 0)
