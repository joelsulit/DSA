Challenge 27: Container With Most Water
height = [1,8,6,2,5,4,8,3,7]
l,r = 0,len(height)-1
max_area = 0
while l<r:
    max_area = max(max_area, min(height[l],height[r])*(r-l))
    if height[l]<height[r]:
        l += 1
    else:
        r -= 1
print(max_area)
