Challenge 24: Largest Rectangle in Histogram
heights = [2,1,5,6,2,3]
stack = []
max_area = 0
heights.append(0)
for i,h in enumerate(heights):
    while stack and heights[stack[-1]]>h:
        H = heights[stack.pop()]
        W = i if not stack else i-stack[-1]-1
        max_area = max(max_area,H*W)
    stack.append(i)
print(max_area)
