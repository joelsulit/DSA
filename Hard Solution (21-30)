Challenge 28: Merge Intervals
intervals = [[1,3],[2,6],[8,10],[15,18]]
intervals.sort()
res = [intervals[0]]
for start,end in intervals[1:]:
    last_end = res[-1][1]
    if start <= last_end:
        res[-1][1] = max(last_end,end)
    else:
        res.append([start,end])
