Challenge 21: Next Greater Element
nums = [4,5,2,10,8]
res = [-1]*len(nums)
stack = []
for i,n in enumerate(nums):
    while stack and nums[stack[-1]]<n:
        idx = stack.pop()
        res[idx] = n
    stack.append(i)
print(res)
