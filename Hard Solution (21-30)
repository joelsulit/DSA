Challenge 23: Stock Span Problem
prices = [100,80,60,70,60,75,85]
res = []
stack = []
for i,p in enumerate(prices):
    span = 1
    while stack and stack[-1][0]<=p:
        span += stack.pop()[1]
    stack.append((p,span))
    res.append(span)
print(res)
