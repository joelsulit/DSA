Challenge 36: Search Range
nums = [5,7,7,8,8,10]
target = 8
def findBound(left=True):
    l,r = 0,len(nums)-1
    bound = -1
    while l<=r:
        m = (l+r)//2
        if nums[m]==target:
            bound = m
            if left:
                r = m-1
            else:
                l = m+1
        elif nums[m]<target:
            l = m+1
        else:
            r = m-1
    return bound
print([findBound(True),findBound(False)])
