Challenge 43: Reverse Linked List
head = ListNode(1)
head.next = ListNode(2)
head.next.next = ListNode(3)
head.next.next.next = ListNode(4)
head.next.next.next.next = ListNode(5)
prev = None
curr = head
while curr:
    nxt = curr.next
    curr.next = prev
    prev = curr
    curr = nxt
# print reversed list
res = []
curr = prev
while curr:
    res.append(curr.val)
    curr = curr.next
print(res)
