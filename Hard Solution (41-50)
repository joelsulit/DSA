Challenge 41: Detect Cycle in Linked List
class ListNode:
    def __init__(self,val):
        self.val = val
        self.next = None
head = ListNode(3)
head.next = ListNode(2)
head.next.next = ListNode(0)
head.next.next.next = ListNode(-4)
head.next.next.next.next = head.next  # cycle
slow = fast = head
found = False
while fast and fast.next:
    slow = slow.next
    fast = fast.next.next
    if slow==fast:
        found = True
        break
print(found)
